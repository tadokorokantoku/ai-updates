---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { DEFAULT_THEME, themeStyle, type ThemeKey } from '../themes';
import SiteHeader from '../components/SiteHeader.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  theme?: ThemeKey;
  locale?: 'ja';
}

const { title = 'Claude Code Updates', theme = DEFAULT_THEME } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-base-200 text-base-content antialiased" style={themeStyle(theme)}>
    <SiteHeader />

    <div class="mx-auto flex max-w-7xl gap-10 px-6 py-8">
      <Sidebar />
      <main class="min-w-0 flex-1">
        <slot />
      </main>
    </div>

    <footer class="footer footer-center mt-16 border-t border-base-300 bg-base-100 p-6">
      <aside>
        <p class="text-xs text-base-content/60">非公式のClaude Codeリリース情報サイト</p>
      </aside>
    </footer>
  </body>
</html>
