---
import type { CollectionEntry } from 'astro:content';
import { renderInlineCode } from '../utils/inlineCode';

type Command = CollectionEntry<'commands'> | CollectionEntry<'commands-ja'>;

interface Props {
  commands: Command[];
  basePath: string;
}
const { commands, basePath } = Astro.props;
---

{commands.length > 0 && (
  <section class="mt-10">
    <h2 class="text-xl font-semibold">このバージョンで導入されたコマンド</h2>
    <ul class="mt-4 space-y-2">
      {commands.map((c) => (
        <li>
          <a
            href={`${basePath}/${c.id}`}
            class="card card-border card-sm bg-base-100 transition-colors hover:border-primary"
          >
            <div class="card-body flex-row items-baseline gap-3 py-3">
              <code class="font-mono text-sm font-semibold text-primary">{c.data.name}</code>
              <span class="text-sm text-base-content/70" set:html={renderInlineCode(c.data.description)} />
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
