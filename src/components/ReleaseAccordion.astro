---
import type { CollectionEntry } from 'astro:content';
import HighlightPills from './HighlightPills.astro';
import Chevron from './Chevron.astro';
import IntroducedCommands from './IntroducedCommands.astro';
import { renderInlineCode } from '../utils/inlineCode';

type Release = CollectionEntry<'releases'> | CollectionEntry<'releases-ja'>;
type Command = CollectionEntry<'commands'> | CollectionEntry<'commands-ja'>;
type RenderedRelease = { release: Release; Content: any; commands: Command[] };

interface Props {
  items: RenderedRelease[];
  basePath: string;
  commandsBasePath: string;
  autoOpenLatest?: boolean;
}
const { items, basePath, commandsBasePath, autoOpenLatest = false } = Astro.props;
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });

const summaryOf = (r: Release): string => {
  if (r.data.highlights && r.data.highlights.length > 0) return r.data.highlights[0];
  const body = (r as unknown as { body?: string }).body ?? '';
  const firstLine = body.split('\n').map((l) => l.trim()).find((l) => l.length > 0) ?? '';
  return firstLine.replace(/^[-*]\s+/, '');
};

type Tip =
  | { kind: 'highlight'; html: string }
  | { kind: 'command'; name: string };

const MODEL_RE = /\b((?:Claude )?(?:Opus|Sonnet|Haiku)(?: \d+(?:\.\d+)?)?(?: x\w+)?)/g;
const CODE_CHIP_BASE = 'mx-0.5 inline-block rounded px-1.5 py-0.5 font-mono text-xs font-semibold';
const MODEL_CHIP = `${CODE_CHIP_BASE} !text-error !bg-error/15`;
const CMD_CHIP = `${CODE_CHIP_BASE} !text-success !bg-success/15`;

const escapeHtml = (s: string): string =>
  s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

const renderTooltipHtml = (text: string): string => {
  const parts = escapeHtml(text).split(/(`[^`]+`)/);
  return parts
    .map((part) => {
      if (part.startsWith('`') && part.endsWith('`') && part.length >= 2) {
        return `<code class="${CMD_CHIP}">${part.slice(1, -1)}</code>`;
      }
      return part.replace(MODEL_RE, `<code class="${MODEL_CHIP}">$1</code>`);
    })
    .join('');
};

const tooltipOf = (r: Release, commands: Command[]): Tip | null => {
  if (r.data.highlights && r.data.highlights.length > 0) {
    return { kind: 'highlight', html: renderTooltipHtml(r.data.highlights[0]) };
  }
  if (commands.length > 0) return { kind: 'command', name: commands[0].data.name };
  return null;
};
---

<ol
  class="mt-8 space-y-3"
  id="release-list"
  data-base-path={basePath}
  data-auto-open-latest={autoOpenLatest ? 'true' : 'false'}
>
  {items.map(({ release: r, Content, commands }) => {
    const tip = tooltipOf(r, commands);
    return (
    <li
      id={`release-${r.data.version}`}
      class={`scroll-mt-32 block ${tip ? 'tooltip tooltip-right tooltip-open w-full text-left [--tt-bg:color-mix(in_oklab,var(--color-primary)_10%,var(--color-base-100))] has-[.release-card.open]:after:!opacity-0 [&:has(.release-card.open)_.tooltip-content]:!opacity-0' : ''}`}
    >
      {tip && (
        <div class="tooltip-content !max-w-[240px] !border !border-primary/25 !text-primary !shadow-sm">
          {tip.kind === 'highlight' ? (
            <span class="break-all" set:html={tip.html} />
          ) : (
            <span><code class={CMD_CHIP}>{tip.name}</code> の追加</span>
          )}
        </div>
      )}
      <div
        class="release-card card card-border bg-base-100 transition-colors hover:border-primary [&.open]:border-primary [&.open]:shadow-md"
        data-version={r.data.version}
      >
        <button
          type="button"
          class="release-toggle group/toggle flex w-full cursor-pointer items-baseline justify-between gap-4 px-5 py-4 text-left"
          aria-expanded="false"
        >
          <div class="flex shrink-0 items-baseline gap-4">
            <Chevron class="self-center text-base-content/40 transition-transform [.release-card.open_&]:rotate-90" />
            <span class="text-xl font-semibold">v{r.data.version}</span>
            <span class="whitespace-nowrap text-xs text-base-content/60">{dateFmt.format(r.data.date)}</span>
          </div>
          {summaryOf(r) && (
            <span
              class="hidden min-w-0 flex-1 truncate text-right text-xs text-base-content/70 sm:inline"
              set:html={renderInlineCode(summaryOf(r))}
            />
          )}
        </button>
        <div class="release-body">
          <div class="release-body-inner">
            <div class="border-t border-base-300 px-6 py-5">
              <div class="mb-4 flex items-start justify-between gap-4">
                {r.data.highlights && r.data.highlights.length > 0 ? (
                  <HighlightPills highlights={r.data.highlights} />
                ) : (
                  <span />
                )}
                <a
                  href={`${basePath}/${r.data.version}/detail`}
                  class="link link-hover shrink-0 whitespace-nowrap text-xs text-base-content/60 hover:text-primary"
                >
                  単独ページで開く →
                </a>
              </div>
              <IntroducedCommands commands={commands} basePath={commandsBasePath} />
              <article class="prose prose-slate prose-sm max-w-none">
                <Content />
              </article>
            </div>
          </div>
        </div>
      </div>
    </li>
    );
  })}
</ol>

<script is:inline>
  (() => {
    const list = document.getElementById('release-list');
    if (!list) return;
    const basePath = list.dataset.basePath || '';
    const autoOpenLatest = list.dataset.autoOpenLatest === 'true';
    const cards = list.querySelectorAll('.release-card');
    const byVersion = new Map();
    cards.forEach((d) => byVersion.set(d.dataset.version, d));

    const matchPath = () => {
      if (!location.pathname.startsWith(basePath + '/')) return null;
      const rest = location.pathname.slice(basePath.length + 1).replace(/\/$/, '');
      return rest ? decodeURIComponent(rest) : null;
    };
    const matchHash = () => {
      const m = location.hash.match(/^#release-(.+)$/);
      return m ? decodeURIComponent(m[1]) : null;
    };

    const findOpen = () => [...cards].find((d) => d.classList.contains('open')) || null;

    const setOpen = (card, open) => {
      card.classList.toggle('open', open);
      const btn = card.querySelector('.release-toggle');
      btn?.setAttribute('aria-expanded', String(open));
    };

    const openVersion = (version, { scroll = true, push = false } = {}) => {
      const card = byVersion.get(version);
      if (!card) return;
      const opened = findOpen();
      if (opened === card) return;
      if (opened) setOpen(opened, false);
      setOpen(card, true);
      if (push) history.pushState({ version }, '', `${basePath}/${version}`);
      if (scroll) {
        requestAnimationFrame(() => {
          const li = card.closest('li');
          li?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
    };

    const closeVersion = (card, { push = true } = {}) => {
      if (!card.classList.contains('open')) return;
      setOpen(card, false);
      if (push) history.pushState({}, '', basePath);
    };

    const closeAll = () => {
      const open = findOpen();
      if (open) closeVersion(open, { push: false });
    };

    window.openRelease = openVersion;

    cards.forEach((card) => {
      const button = card.querySelector('.release-toggle');
      if (!button) return;
      button.addEventListener('click', () => {
        const version = card.dataset.version;
        if (!version) return;
        if (card.classList.contains('open')) {
          closeVersion(card);
        } else {
          openVersion(version, { scroll: false, push: true });
        }
      });
    });

    window.addEventListener('popstate', () => {
      const version = matchPath();
      if (version) {
        openVersion(version, { scroll: true });
      } else {
        closeAll();
      }
    });

    const initial = matchPath() || matchHash();
    if (initial) {
      requestAnimationFrame(() => openVersion(initial, { scroll: true }));
    } else if (autoOpenLatest) {
      const latest = cards[0]?.dataset.version;
      if (latest) requestAnimationFrame(() => openVersion(latest, { scroll: false }));
    }
  })();
</script>
