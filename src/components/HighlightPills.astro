---
import { renderInlineCode } from '../utils/inlineCode';

interface Props {
  highlights: string[];
  class?: string;
}
const { highlights, class: className = 'flex flex-wrap gap-2' } = Astro.props;
---
<ul class={className}>
  {highlights.map((h) => (
    <li
      class="rounded-full bg-accent-100 px-3 py-1 text-xs text-accent-800"
      set:html={renderInlineCode(h)}
    />
  ))}
</ul>
