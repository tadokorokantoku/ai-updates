---
import { renderInlineCode } from '../utils/inlineCode';

interface Props {
  highlights: string[];
  class?: string;
}
const { highlights, class: className = 'flex flex-wrap gap-2' } = Astro.props;
---
<ul class={className}>
  {highlights.map((h) => (
    <li
      class="badge badge-primary badge-soft"
      set:html={renderInlineCode(h)}
    />
  ))}
</ul>
