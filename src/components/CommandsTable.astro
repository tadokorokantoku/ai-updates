---
import type { CollectionEntry } from 'astro:content';
import { renderInlineCode } from '../utils/inlineCode';

type Command = CollectionEntry<'commands'> | CollectionEntry<'commands-ja'>;

interface Props {
  commands: Command[];
  basePath: string;
  releasesBasePath: string;
}
const { commands, basePath, releasesBasePath } = Astro.props;

const active = commands
  .filter((c) => !c.data.deprecated)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const deprecated = commands
  .filter((c) => c.data.deprecated)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<table class="mt-8 w-full overflow-hidden rounded-lg border border-slate-200 bg-white text-sm">
  <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
    <tr>
      <th class="px-4 py-3">コマンド</th>
      <th class="px-4 py-3">説明</th>
      <th class="px-4 py-3 whitespace-nowrap">導入バージョン</th>
    </tr>
  </thead>
  <tbody class="divide-y divide-slate-200">
    {active.map((c) => (
      <tr class="hover:bg-slate-50">
        <td class="px-4 py-3">
          <a href={`${basePath}/${c.id}`} class="font-mono font-semibold text-accent-700 hover:underline">
            {c.data.name}
          </a>
        </td>
        <td class="px-4 py-3 text-slate-700" set:html={renderInlineCode(c.data.description)} />
        <td class="px-4 py-3 whitespace-nowrap">
          <a href={`${releasesBasePath}/${c.data.introducedIn}`} class="text-accent-600 hover:underline">
            v{c.data.introducedIn}
          </a>
        </td>
      </tr>
    ))}
  </tbody>
</table>

{deprecated.length > 0 && (
  <section class="mt-10">
    <h2 class="text-lg font-semibold text-slate-700">非推奨</h2>
    <ul class="mt-3 space-y-1 text-sm text-slate-500">
      {deprecated.map((c) => (
        <li>
          <code class="font-mono">{c.data.name}</code>
          {c.data.deprecatedIn && <span> (v{c.data.deprecatedIn} で非推奨)</span>}
        </li>
      ))}
    </ul>
  </section>
)}
