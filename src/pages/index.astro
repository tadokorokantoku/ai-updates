---
import Layout from '../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import HighlightPills from '../components/HighlightPills.astro';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const latest = releases[0];
const { Content } = await render(latest);
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });
---

<Layout title="Claude Code Updates - 最新リリース">
  <section class="mb-10">
    <p class="text-sm text-slate-500">最新リリース</p>
    <div class="mt-2 flex items-baseline gap-4">
      <h1 class="text-4xl font-bold tracking-tight">v{latest.data.version}</h1>
      <time class="text-sm text-slate-500">{dateFmt.format(latest.data.date)}</time>
    </div>
    {latest.data.highlights && <HighlightPills highlights={latest.data.highlights} class="mt-4 flex flex-wrap gap-2" />}
  </section>

  <article class="prose prose-slate max-w-none rounded-lg border border-slate-200 bg-white p-8">
    <Content />
  </article>

  <div class="mt-6 flex justify-between text-sm">
    <a href={`/releases/${latest.data.version}`} class="text-accent-600 hover:underline">このリリースの詳細 →</a>
    <a href="/releases" class="text-accent-600 hover:underline">過去のリリース一覧 →</a>
  </div>
</Layout>
