---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import ReleaseHeatmap from '../../../components/ReleaseHeatmap.astro';
import ReleaseAccordion from '../../../components/ReleaseAccordion.astro';

const releases = (await getCollection('releases-ja')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const items = await Promise.all(
  releases.map(async (r) => {
    const { Content } = await render(r);
    return { release: r, Content };
  })
);
---

<Layout title="リリース一覧 - Claude Code Updates" locale="ja">
  <h1 class="text-3xl font-bold tracking-tight">リリース一覧</h1>
  <p class="mt-2 text-sm text-slate-600">バージョンを選ぶと変更内容が表示されます</p>

  <ReleaseHeatmap releases={releases} />
  <ReleaseAccordion items={items} basePath="/ja/releases" autoOpenLatest={true} />
</Layout>
