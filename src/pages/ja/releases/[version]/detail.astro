---
import Layout from '../../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import HighlightPills from '../../../../components/HighlightPills.astro';
import IntroducedCommands from '../../../../components/IntroducedCommands.astro';

export async function getStaticPaths() {
  const releases = await getCollection('releases-ja');
  return releases.map((release) => ({
    params: { version: release.data.version },
    props: { release },
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);
const commands = (await getCollection('commands-ja')).filter(
  (c) => c.data.introducedIn === release.data.version
);
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });
---

<Layout title={`v${release.data.version} - Claude Code Updates`} locale="ja">
  <a href="/ja/releases" class="link link-primary link-hover text-sm">← リリース一覧</a>

  <header class="mt-4 mb-8">
    <div class="flex items-baseline gap-4">
      <h1 class="text-4xl font-bold tracking-tight">v{release.data.version}</h1>
      <time class="text-sm text-base-content/60">{dateFmt.format(release.data.date)}</time>
    </div>
    {release.data.highlights && <HighlightPills highlights={release.data.highlights} class="mt-4 flex flex-wrap gap-2" />}
  </header>

  <IntroducedCommands commands={commands} basePath="/ja/commands" />

  <div class="card card-border bg-base-100">
    <article class="card-body prose prose-slate max-w-none">
      <Content />
    </article>
  </div>
</Layout>
