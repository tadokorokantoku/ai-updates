---
// /ja/ は /ja/releases/ にリダイレクト。/ja/releases/ は最新のリリースカードを
// デフォルトで開いた状態で表示する。
const target = '/ja/releases';
---
<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>Claude Code Updates</title>
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <script is:inline set:html={`location.replace(${JSON.stringify(target)});`}></script>
  </head>
  <body>
    <noscript>
      <p>
        JavaScriptが無効な場合は <a href={target}>{target}</a> へ移動してください。
      </p>
    </noscript>
  </body>
</html>
