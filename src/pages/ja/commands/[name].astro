---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { renderInlineCode } from '../../../utils/inlineCode';

export async function getStaticPaths() {
  const commands = await getCollection('commands-ja');
  return commands.map((command) => ({
    params: { name: command.id },
    props: { command },
  }));
}

const { command } = Astro.props;
const { Content } = await render(command);
---

<Layout title={`${command.data.name} - Claude Code Updates`} locale="ja">
  <a href="/ja/commands" class="text-sm text-accent-600 hover:underline">← コマンド一覧</a>

  <header class="mt-4 mb-8">
    <h1 class="font-mono text-4xl font-bold tracking-tight text-accent-700">
      {command.data.name}
    </h1>
    <p class="mt-3 text-slate-700" set:html={renderInlineCode(command.data.description)}></p>
    <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <div class="flex gap-2">
        <dt class="text-slate-500">導入:</dt>
        <dd>
          <a href={`/ja/releases/${command.data.introducedIn}`} class="font-semibold text-accent-600 hover:underline">
            v{command.data.introducedIn}
          </a>
        </dd>
      </div>
      <div class="flex gap-2">
        <dt class="text-slate-500">区分:</dt>
        <dd class="font-semibold">{command.data.category}</dd>
      </div>
      {command.data.deprecated && (
        <div class="flex gap-2">
          <dt class="text-slate-500">状態:</dt>
          <dd class="font-semibold text-red-600">
            非推奨{command.data.deprecatedIn && ` (v${command.data.deprecatedIn} 以降)`}
          </dd>
        </div>
      )}
    </dl>
  </header>

  <article class="prose prose-slate max-w-none rounded-lg border border-slate-200 bg-white p-8">
    <Content />
  </article>
</Layout>
