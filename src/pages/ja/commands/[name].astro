---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { renderInlineCode } from '../../../utils/inlineCode';

export async function getStaticPaths() {
  const commands = await getCollection('commands-ja');
  return commands.map((command) => ({
    params: { name: command.id },
    props: { command },
  }));
}

const { command } = Astro.props;
const { Content } = await render(command);
---

<Layout title={`${command.data.name} - Claude Code Updates`}>
  <a href="/ja/commands" class="link link-primary link-hover text-sm">← コマンド一覧</a>

  <header class="mt-4 mb-8">
    <h1 class="font-mono text-4xl font-bold tracking-tight text-primary">
      {command.data.name}
    </h1>
    <p class="mt-3 text-base-content/80" set:html={renderInlineCode(command.data.description)}></p>
    <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm">
      <div class="flex items-center gap-2">
        <dt class="text-base-content/60">導入:</dt>
        <dd>
          <a href={`/ja/releases/${command.data.introducedIn}`} class="badge badge-primary badge-soft font-semibold hover:underline">
            v{command.data.introducedIn}
          </a>
        </dd>
      </div>
      <div class="flex items-center gap-2">
        <dt class="text-base-content/60">区分:</dt>
        <dd><span class="badge badge-neutral badge-soft">{command.data.category}</span></dd>
      </div>
      {command.data.deprecated && (
        <div class="flex items-center gap-2">
          <dt class="text-base-content/60">状態:</dt>
          <dd>
            <span class="badge badge-error badge-soft font-semibold">
              非推奨{command.data.deprecatedIn && ` (v${command.data.deprecatedIn} 以降)`}
            </span>
          </dd>
        </div>
      )}
    </dl>
  </header>

  <div class="card card-border bg-base-100">
    <article class="card-body prose prose-slate max-w-none">
      <Content />
    </article>
  </div>
</Layout>
