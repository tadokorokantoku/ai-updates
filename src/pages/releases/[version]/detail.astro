---
import Layout from '../../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import HighlightPills from '../../../components/HighlightPills.astro';
import IntroducedCommands from '../../../components/IntroducedCommands.astro';

export async function getStaticPaths() {
  const releases = await getCollection('releases');
  return releases.map((release) => ({
    params: { version: release.data.version },
    props: { release },
  }));
}

const { release } = Astro.props;
const { Content } = await render(release);
const commands = (await getCollection('commands')).filter(
  (c) => c.data.introducedIn === release.data.version
);
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });
---

<Layout title={`v${release.data.version} - Claude Code Updates`}>
  <a href="/releases" class="text-sm text-accent-600 hover:underline">← リリース一覧</a>

  <header class="mt-4 mb-8">
    <div class="flex items-baseline gap-4">
      <h1 class="text-4xl font-bold tracking-tight">v{release.data.version}</h1>
      <time class="text-sm text-slate-500">{dateFmt.format(release.data.date)}</time>
    </div>
    {release.data.highlights && <HighlightPills highlights={release.data.highlights} class="mt-4 flex flex-wrap gap-2" />}
  </header>

  <IntroducedCommands commands={commands} basePath="/commands" />

  <article class="prose prose-slate max-w-none rounded-lg border border-slate-200 bg-white p-8">
    <Content />
  </article>
</Layout>
