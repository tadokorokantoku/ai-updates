---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import ReleaseHeatmap from '../../components/ReleaseHeatmap.astro';
import ReleaseAccordion from '../../components/ReleaseAccordion.astro';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const commands = await getCollection('commands');
const items = await Promise.all(
  releases.map(async (r) => {
    const { Content } = await render(r);
    const cmds = commands.filter((c) => c.data.introducedIn === r.data.version);
    return { release: r, Content, commands: cmds };
  })
);
---

<Layout title="リリース一覧 - Claude Code Updates">
  <h1 class="text-3xl font-bold tracking-tight">リリース一覧</h1>
  <p class="mt-2 text-sm text-base-content/70">バージョンを選ぶと変更内容が表示されます</p>

  <ReleaseHeatmap releases={releases} />
  <ReleaseAccordion items={items} basePath="/releases" commandsBasePath="/commands" />
</Layout>
