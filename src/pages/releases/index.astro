---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });

// --- contribution heatmap ---
const DAY_MS = 24 * 60 * 60 * 1000;
const toKey = (d: Date) => {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}-${m}-${day}`;
};

const cmpVer = (a: string, b: string) => {
  const pa = a.split('.').map(Number);
  const pb = b.split('.').map(Number);
  for (let i = 0; i < 3; i++) if (pa[i] !== pb[i]) return pb[i] - pa[i];
  return 0;
};
const counts = new Map<string, { count: number; versions: string[] }>();
for (const r of releases) {
  const k = toKey(r.data.date);
  const entry = counts.get(k) ?? { count: 0, versions: [] };
  entry.count++;
  entry.versions.push(r.data.version);
  counts.set(k, entry);
}
for (const entry of counts.values()) entry.versions.sort(cmpVer);

const latest = releases[0].data.date;
// end = Saturday of week containing latest
const end = new Date(Date.UTC(latest.getUTCFullYear(), latest.getUTCMonth(), latest.getUTCDate()));
end.setUTCDate(end.getUTCDate() + (6 - end.getUTCDay()));
const WEEKS = 53;
const start = new Date(end.getTime() - (WEEKS * 7 - 1) * DAY_MS);

type Cell = { date: Date; key: string; count: number; versions: string[] } | null;
const weeks: Cell[][] = [];
for (let w = 0; w < WEEKS; w++) {
  const col: Cell[] = [];
  for (let d = 0; d < 7; d++) {
    const date = new Date(start.getTime() + (w * 7 + d) * DAY_MS);
    if (date > end) { col.push(null); continue; }
    const key = toKey(date);
    const entry = counts.get(key);
    col.push({ date, key, count: entry?.count ?? 0, versions: entry?.versions ?? [] });
  }
  weeks.push(col);
}

const levelClass = (n: number) => {
  if (n === 0) return 'fill-slate-200';
  if (n === 1) return 'fill-accent-200';
  if (n <= 3) return 'fill-accent-400';
  if (n <= 6) return 'fill-accent-600';
  return 'fill-accent-800';
};

// month labels (week of first appearance) and year labels on a separate row above
const monthLabels: { week: number; label: string }[] = [];
const yearLabels: { week: number; label: string }[] = [];
let lastMonth = -1;
let lastYear = -1;
for (let w = 0; w < WEEKS; w++) {
  const firstDay = weeks[w][0];
  if (!firstDay) continue;
  const m = firstDay.date.getUTCMonth();
  const y = firstDay.date.getUTCFullYear();
  if (m !== lastMonth) {
    monthLabels.push({ week: w, label: `${m + 1}月` });
    lastMonth = m;
  }
  if (y !== lastYear) {
    yearLabels.push({ week: w, label: `${y}` });
    lastYear = y;
  }
}

const CELL = 11;
const GAP = 3;
const STRIDE = CELL + GAP;
const PAD_LEFT = 24;
const YEAR_Y = 10;
const MONTH_Y = 24;
const PAD_TOP = 30;
const svgW = PAD_LEFT + WEEKS * STRIDE;
const svgH = PAD_TOP + 7 * STRIDE;
const totalReleases = releases.length;
const dateFmtShort = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'medium' });
---

<Layout title="リリース一覧 - Claude Code Updates">
  <h1 class="text-3xl font-bold tracking-tight">リリース一覧</h1>
  <p class="mt-2 text-sm text-slate-600">バージョンを選ぶと変更内容が表示されます</p>

  <section class="sticky top-12 z-[5] mt-6 rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-3 flex items-baseline justify-between">
      <h2 class="text-sm font-semibold text-slate-700">
        過去53週間のリリース活動
        <span class="ml-2 font-normal text-slate-500">{totalReleases}件</span>
      </h2>
      <div class="flex items-center gap-1.5 text-xs text-slate-500">
        <span>少</span>
        <svg width="11" height="11" class="inline-block"><rect width="11" height="11" rx="2" class="fill-slate-200" /></svg>
        <svg width="11" height="11" class="inline-block"><rect width="11" height="11" rx="2" class="fill-accent-200" /></svg>
        <svg width="11" height="11" class="inline-block"><rect width="11" height="11" rx="2" class="fill-accent-400" /></svg>
        <svg width="11" height="11" class="inline-block"><rect width="11" height="11" rx="2" class="fill-accent-600" /></svg>
        <svg width="11" height="11" class="inline-block"><rect width="11" height="11" rx="2" class="fill-accent-800" /></svg>
        <span>多</span>
      </div>
    </div>
    <div class="relative overflow-x-auto" id="heatmap-wrap">
      <svg width={svgW} height={svgH} class="block" role="img" aria-label="リリース活動ヒートマップ">
        {yearLabels.map((y) => (
          <text x={PAD_LEFT + y.week * STRIDE} y={YEAR_Y} class="fill-slate-700" style="font-size: 11px; font-weight: 600;">{y.label}</text>
        ))}
        {monthLabels.map((m) => (
          <text x={PAD_LEFT + m.week * STRIDE} y={MONTH_Y} class="fill-slate-500" style="font-size: 10px;">{m.label}</text>
        ))}
        {['月', '水', '金'].map((d, i) => (
          <text x={0} y={PAD_TOP + (i * 2 + 1) * STRIDE + CELL - 2} class="fill-slate-500" style="font-size: 9px;">{d}</text>
        ))}
        {weeks.map((col, wi) => (
          col.map((cell, di) => cell && (
            <rect
              x={PAD_LEFT + wi * STRIDE}
              y={PAD_TOP + di * STRIDE}
              width={CELL}
              height={CELL}
              rx={2}
              class={`${levelClass(cell.count)} cursor-pointer transition-opacity hover:opacity-80`}
              data-date={dateFmtShort.format(cell.date)}
              data-count={cell.count}
              data-versions={cell.versions.join(',')}
            />
          ))
        ))}
      </svg>
      <div
        id="heatmap-tip"
        class="pointer-events-none absolute left-0 top-0 z-20 hidden -translate-x-1/2 -translate-y-full rounded-md bg-slate-900 px-3 py-2 text-xs text-white shadow-lg ring-1 ring-slate-700/50"
        style="white-space: nowrap;"
      >
        <div class="font-semibold" id="heatmap-tip-date"></div>
        <div class="mt-0.5 text-slate-300" id="heatmap-tip-body"></div>
        <div class="absolute left-1/2 top-full -translate-x-1/2 -translate-y-px h-0 w-0 border-x-4 border-t-4 border-x-transparent border-t-slate-900"></div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const wrap = document.getElementById('heatmap-wrap');
      const tip = document.getElementById('heatmap-tip');
      const tipDate = document.getElementById('heatmap-tip-date');
      const tipBody = document.getElementById('heatmap-tip-body');
      if (!wrap || !tip || !tipDate || !tipBody) return;

      const show = (rect) => {
        const date = rect.getAttribute('data-date');
        const count = Number(rect.getAttribute('data-count'));
        const versions = (rect.getAttribute('data-versions') || '').split(',').filter(Boolean);
        tipDate.textContent = date;
        if (count === 0) {
          tipBody.textContent = 'リリースなし';
        } else {
          tipBody.textContent = `${count}件: ${versions.map((v) => 'v' + v).join(', ')}`;
        }
        const wrapBox = wrap.getBoundingClientRect();
        const rectBox = rect.getBoundingClientRect();
        const x = rectBox.left - wrapBox.left + rectBox.width / 2 + wrap.scrollLeft;
        const y = rectBox.top - wrapBox.top - 6 + wrap.scrollTop;
        tip.style.left = x + 'px';
        tip.style.top = y + 'px';
        tip.classList.remove('hidden');
      };
      const hide = () => tip.classList.add('hidden');

      const flash = (el) => {
        el.classList.add('ring-2', 'ring-accent-400', 'rounded-lg');
        setTimeout(() => el.classList.remove('ring-2', 'ring-accent-400', 'rounded-lg'), 1600);
      };

      wrap.querySelectorAll('rect[data-date]').forEach((rect) => {
        rect.addEventListener('mouseenter', () => show(rect));
        rect.addEventListener('mouseleave', hide);
        rect.addEventListener('click', () => {
          const versions = (rect.getAttribute('data-versions') || '').split(',').filter(Boolean);
          if (versions.length === 0) return;
          const target = document.getElementById('release-' + versions[0]);
          if (!target) return;
          target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          flash(target);
          hide();
        });
      });
    })();
  </script>

  <ol class="mt-8 space-y-3">
    {releases.map((r) => (
      <li id={`release-${r.data.version}`} class="scroll-mt-24 transition-colors duration-700">
        <a
          href={`/releases/${r.data.version}`}
          class="flex items-baseline justify-between rounded-lg border border-slate-200 bg-white px-5 py-4 transition-colors hover:border-accent-400"
        >
          <div class="flex items-baseline gap-4">
            <span class="text-xl font-semibold">v{r.data.version}</span>
            <span class="text-xs text-slate-500">{dateFmt.format(r.data.date)}</span>
          </div>
          {r.data.highlights && r.data.highlights.length > 0 && (
            <span class="hidden text-xs text-slate-600 sm:inline">{r.data.highlights[0]}</span>
          )}
        </a>
      </li>
    ))}
  </ol>
</Layout>
