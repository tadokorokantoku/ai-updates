---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const releases = (await getCollection('releases')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const dateFmt = new Intl.DateTimeFormat('ja-JP', { dateStyle: 'long' });
---

<Layout title="リリース一覧 - Claude Code Updates">
  <h1 class="text-3xl font-bold tracking-tight">リリース一覧</h1>
  <p class="mt-2 text-sm text-slate-600">バージョンを選ぶと変更内容が表示されます</p>

  <ol class="mt-8 space-y-3">
    {releases.map((r) => (
      <li>
        <a
          href={`/releases/${r.data.version}`}
          class="flex items-baseline justify-between rounded-lg border border-slate-200 bg-white px-5 py-4 transition-colors hover:border-blue-400"
        >
          <div class="flex items-baseline gap-4">
            <span class="text-xl font-semibold">v{r.data.version}</span>
            <span class="text-xs text-slate-500">{dateFmt.format(r.data.date)}</span>
          </div>
          {r.data.highlights && r.data.highlights.length > 0 && (
            <span class="hidden text-xs text-slate-600 sm:inline">{r.data.highlights[0]}</span>
          )}
        </a>
      </li>
    ))}
  </ol>
</Layout>
