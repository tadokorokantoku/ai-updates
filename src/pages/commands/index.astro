---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('commands');
const active = all.filter((c) => !c.data.deprecated)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const deprecated = all.filter((c) => c.data.deprecated)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<Layout title="コマンド一覧 - Claude Code Updates">
  <h1 class="text-3xl font-bold tracking-tight">コマンド一覧</h1>
  <p class="mt-2 text-sm text-slate-600">現在利用可能なコマンドと、それぞれの導入バージョン</p>

  <table class="mt-8 w-full overflow-hidden rounded-lg border border-slate-200 bg-white text-sm">
    <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
      <tr>
        <th class="px-4 py-3">コマンド</th>
        <th class="px-4 py-3">説明</th>
        <th class="px-4 py-3 whitespace-nowrap">導入バージョン</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-200">
      {active.map((c) => (
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-3">
            <a href={`/commands/${c.id}`} class="font-mono font-semibold text-accent-700 hover:underline">
              {c.data.name}
            </a>
          </td>
          <td class="px-4 py-3 text-slate-700">{c.data.description}</td>
          <td class="px-4 py-3 whitespace-nowrap">
            <a href={`/releases/${c.data.introducedIn}`} class="text-accent-600 hover:underline">
              v{c.data.introducedIn}
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>

  {deprecated.length > 0 && (
    <section class="mt-10">
      <h2 class="text-lg font-semibold text-slate-700">非推奨</h2>
      <ul class="mt-3 space-y-1 text-sm text-slate-500">
        {deprecated.map((c) => (
          <li>
            <code class="font-mono">{c.data.name}</code>
            {c.data.deprecatedIn && <span> (v{c.data.deprecatedIn} で非推奨)</span>}
          </li>
        ))}
      </ul>
    </section>
  )}
</Layout>
